# ---- 数据库配置 ----
# 数据库类型: sqlite / mysql
DATABASE_TYPE=sqlite
# SQLite 数据库文件路径（相对于项目根目录）
SQLITE_DB_PATH=data/langgraph_agent.db
# 如果需要直接指定完整 URL（优先级最高），取消下面注释
# DATABASE_URL=sqlite+aiosqlite:///data/app.db

# ---- 以下 MySQL 配置在 DATABASE_TYPE=mysql 时生效 ----
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=langgraph_agent
DATABASE_POOL_SIZE=50
DATABASE_MAX_OVERFLOW=30

# ---- 应用配置 ----
# 应用监听地址（0.0.0.0 表示所有网络接口）
APP_HOST=0.0.0.0
# 应用监听端口
APP_PORT=8000
# 调试模式（生产环境设为 False）
DEBUG=False
# 跨域允许的源（逗号分隔，生产环境应配置具体域名）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# ---- 文件上传配置 ----
# 文件上传根目录（相对于项目根目录）
UPLOAD_DIR=uploads

# ---- 向量数据库配置 ----
# 向量数据库类型: chroma / qdrant / milvus
VECTOR_STORE_TYPE=chroma
# 向量数据库存储路径（相对于项目根目录）
VECTOR_STORE_PATH=data/chroma
# 向量集合名称
VECTOR_COLLECTION_NAME=knowledge_segments

# ---- Embedding 配置（OpenAI 兼容接口） ----
# API Key
EMBEDDING_API_KEY=
# API Base URL（如 https://api.openai.com/v1）
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# Embedding 模型名称
EMBEDDING_MODEL=BAAI/bge-m3
# 批量大小（每次请求最大文本数）
EMBEDDING_BATCH_SIZE=10

# ---- 文档处理定时任务 ----
# 文档处理轮询间隔（秒）
DOC_PROCESS_INTERVAL=60
# 每次最多处理的文档数
DOC_PROCESS_BATCH_SIZE=5

# ---- 资源市场配置 ----
# 市场服务器地址（初始化时自动写入数据库）
MARKETPLACE_SERVER_URL=https://agent.market.wuguobang.site
# 版本更新检查接口地址
VERSION_CHECK_URL=https://agent.market.wuguobang.site/api/version/latest

# ---- 工具输出截断配置 ----
# 工具输出最大行数（超过时截断并保存到临时文件）
TOOL_OUTPUT_MAX_LINES=500
# 工具输出最大字节数（默认 10KB）
TOOL_OUTPUT_MAX_BYTES=10240
# 截断后预览保留的行数
TOOL_OUTPUT_PREVIEW_LINES=50
# 截断后预览保留的字节数（默认 3KB）
TOOL_OUTPUT_PREVIEW_BYTES=3072

# ---- 日志配置 ----
# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO
# 日志文件目录
LOG_DIR=logs
# 单个日志文件最大字节数（默认 10MB）
LOG_MAX_BYTES=10485760
# 日志文件保留的天数
LOG_BACKUP_DAYS=7
# 日志格式
LOG_FORMAT=[%(asctime)s] [%(name)s] [%(levelname)s] [%(filename)s:%(lineno)d] - %(message)s
# 日志时间格式
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
# Uvicorn 日志格式
UVICORN_LOG_FORMAT=[%(asctime)s] [%(name)s] [%(levelname)s] - %(message)s
# Uvicorn 访问日志格式
UVICORN_ACCESS_LOG_FORMAT=[%(asctime)s] [%(name)s] [%(levelname)s] - %(client_addr)s - "%(request_line)s" %(status_code)s
